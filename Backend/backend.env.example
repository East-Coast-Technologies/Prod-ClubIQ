# Flask settings
FLASK_APP=run.py
FLASK_DEBUG=false
SECRET_KEY=change-me-to-a-strong-random-secret

# Database settings
# Use a full database URL. Do not rely on ${...} expansion inside this file.
DATABASE_URL=postgresql://your-postgres-username:your-postgres-password@postgres:5432/clubiq

# Clerk backend settings
CLERK_ISSUER=https://...
CLERK_AUDIENCE=https://...
CLERK_FRONTEND_API=https://...
CLERK_JWKS_URL=https://...
CLERK_SECRET_KEY=your-clerk-secret-key

# v1 single-club config
SINGLE_CLUB_NAME=

# Production route surface
# local/dev can use true
# production should use false
EXPOSE_LEGACY_API=false

# Scheduler management API
SCHEDULER_API_ENABLED=false

# Optional mail settings
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
